{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soromi",
  "mainBinaryName": "soromi",
  "version": "0.0.1",
  "identifier": "io.soromi.desktop",
  "build": {
    "frontendDist": "../../../packages/gui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @soromi/gui dev",
    "beforeBuildCommand": "pnpm --filter @soromi/gui build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
