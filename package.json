{
  "name": "soromi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "dev:daemon": "cargo run -p soromi-daemon",
    "dev:desktop": "pnpm --filter @soromi/desktop dev",
    "dev:web": "pnpm --filter @soromi/web dev",
    "dev:relay": "pnpm --filter @soromi/relay dev",
    "app:mac": "pnpm --filter @soromi/desktop tauri build --bundles app",
    "gen:protocol": "cargo test -p soromi-protocol --features ts",
    "release": "bash scripts/release.sh",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
